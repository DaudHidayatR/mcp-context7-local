CONTEXT7_API_KEY=your_api_key_here
# Optional but recommended:
# CLIENT_IP_ENCRYPTION_KEY=replace_with_random_secret

BUN_VERSION=1.3.9
GATEWAY_IMAGE_NAME=local/context7-gateway
GATEWAY_IMAGE_TAG=1.0.31
RUNNER_IMAGE_NAME=local/context7-runner
RUNNER_IMAGE_TAG=1.0.0

GATEWAY_HOST_PORT=3100
SESSION_TIMEOUT_MS=300000
REQUEST_TIMEOUT_MS=30000
CHILD_ENV_ALLOWLIST=CONTEXT7_API_KEY,CLIENT_IP_ENCRYPTION_KEY

# Optional bearer auth for /sse, /message, and /mcp:
# GATEWAY_AUTH_TOKEN=replace_with_random_secret

# Optional advanced override. Example:
# STDIO_CMD_JSON=["bun","test/fixtures/fake-stdio-mcp.ts"]

# Runner + RAG
MCP_CONTEXT7_URL=http://context7-gateway:3100/mcp
# MCP_CLOUDFLARE_URL=https://mcp.cloudflare.com/mcp
# CF_API_TOKEN=replace_with_cloudflare_token
CHROMA_URL=http://chroma:8000
RAG_COLLECTION=context7-local
RAG_TOP_K=5
RUNNER_HOST_PORT=3200

# Split Architecture — Go VPS Services
DATABASE_URL=postgres://mcp:mcp_dev_password@localhost:5432/agent_memory?sslmode=disable
EMBED_URL=http://localhost:11434
VPS_RAG_URL=http://localhost:8081
VPS_MEMORY_URL=
WORKER_SECRET=replace_with_random_secret
