{
  "name": "mcp-context7-local",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "bun --watch services/context7-gateway/src/index.ts",
    "dev:runner": "bun --watch apps/runner/src/index.ts",
    "start": "bun run services/context7-gateway/src/index.ts",
    "start:runner": "bun run apps/runner/src/index.ts",
    "test": "bun test",
    "typecheck": "./node_modules/.bin/tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@openai/agents": "^0.7.2",
    "zod": "^4.3.6"
  }
}
